{
  "installCommand": "npm --prefix frontend install",
  "buildCommand": "VITE_APP_BUILD_ID=$VERCEL_GIT_COMMIT_SHA npm --prefix frontend run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/ping",
      "schedule": "*/5 * * * *"
    }
  ]
}
