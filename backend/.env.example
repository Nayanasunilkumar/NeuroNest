# NeuroNest Backend — Environment Variables Template
# Copy this to .env and fill in your values.
# NEVER commit the actual .env file.

# ----- Database -----
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&connect_timeout=10
FLASK_APP=app.py
FLASK_ENV=production

# ----- Security -----
SECRET_KEY=replace-with-long-random-string
JWT_SECRET_KEY=replace-with-long-random-string
JWT_ACCESS_TOKEN_EXPIRES_HOURS=12

# ----- Operational Flags -----
ENABLE_DIAGNOSTIC_ROUTES=false
ALLOW_DEV_DOCTOR_BOOTSTRAP=false
VITALS_REQUIRE_DEVICE_AUTH=true
VITALS_DEVICE_TOKEN=replace-with-device-shared-secret
VITALS_DEVICE_ID=replace-with-device-id
VITALS_DEVICE_PATIENT_ID=
VITALS_DEVICE_PATIENT_EMAIL=

# ----- Cloudinary (https://cloudinary.com — free tier) -----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----- WebRTC NAT traversal (Metered.ca or Twilio Network Traversal) -----
# Render must provide all three values together. Use comma-separated URLs when
# your provider gives multiple transports, for example:
# TURN_URLS=turn:your-domain.metered.live:80,turn:your-domain.metered.live:443,turns:your-domain.metered.live:443
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# ----- App -----
FLASK_ENV=production
